<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.1 Chrome/142.0.7444.265 Electron/39.8.0 Safari/537.36" version="29.6.1">
  <diagram name="Page-1" id="MYDnhtvzLtZovVrTTYT6">
    <mxGraphModel dx="2593" dy="1835" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="19685" pageHeight="19685" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="6N5ySrmgoOt3BQ2LsJAN-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Design an e-commerce system with following requirements:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;1. user login service&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;2. search service&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;3. product catalog service&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;4. cart service&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;5. order status service&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;6. check out service&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;optimize the product searching and inventory stock management in real time&lt;/font&gt;.&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="680" x="3270" y="2040" as="geometry" />
        </mxCell>
        <mxCell id="6N5ySrmgoOt3BQ2LsJAN-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Funcitonal Requirements:&amp;nbsp;&lt;div&gt;1. User should be able to Register and Login&lt;/div&gt;&lt;div&gt;2. User should be able to search and view the products without login&lt;/div&gt;&lt;div&gt;3. User should be able to add the item to cart&lt;/div&gt;&lt;div&gt;4. User should be able to checkout&lt;/div&gt;&lt;div&gt;5. User should be able to view order status&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Non-Funcitonal Requirements:&lt;/div&gt;&lt;div&gt;1. Should be able to handle 1.5 milion of daily active users&lt;/div&gt;&lt;div&gt;2. Should be able to handle multiple chekcouts at once and update the inventory as per&lt;/div&gt;&lt;div&gt;3. Latency should be &amp;lt;= 300 ms&lt;/div&gt;&lt;div&gt;4. Payment and checkout should be Consistent&lt;/div&gt;&lt;div&gt;5. Maintain availability for product search, view&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="670" x="3230" y="2330" as="geometry" />
        </mxCell>
        <mxCell id="6N5ySrmgoOt3BQ2LsJAN-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Database:&lt;div&gt;User: {user_id, name, address, phone_number, cart_id}&lt;/div&gt;&lt;div&gt;Products: {product_id, title, bio, vendor, price, discount, rating, inventory_id}&lt;/div&gt;&lt;div&gt;Inventory: {inventory_id, product_id, vendor, available_stock}&lt;/div&gt;&lt;div&gt;Cart: {cart_id, products_id, quantity}&lt;/div&gt;&lt;div&gt;Order_Status: {order_id, status, product_id, quantity, delivery_date}&lt;/div&gt;&lt;div&gt;Payment: {payment_id, order_id, status, total_amount, discout}&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="580" x="3270" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="6N5ySrmgoOt3BQ2LsJAN-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="API&#39;s:&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;div&gt;api/User:&lt;/div&gt;&lt;div&gt;Get: { user_id}&amp;nbsp; -&amp;gt;&amp;nbsp; returns {user_id, name, address, phone_numeber, cart_id}&lt;/div&gt;&lt;div&gt;Post: {name, address, phone_number}&amp;nbsp; -&amp;gt;&amp;nbsp; returns {code(success or fail}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;api/Search:&lt;/div&gt;&lt;div&gt;Get: { some string keyword } -&amp;gt; returns { List &amp;lt;product_id, name, thumbnail_url, rating, price, discount&amp;gt; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;api/Product:&lt;/div&gt;&lt;div&gt;Get: {product_id} -&amp;gt; returns {product_id, name, image_url, rating, bio, discount, price, vendor}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;api/Cart:&amp;nbsp;&lt;/div&gt;&lt;div&gt;Get: {cart_id} -&amp;gt; returns {cart_id, List&amp;lt;products_id, quantity&amp;gt;}&lt;/div&gt;&lt;div&gt;Post: {product_id} -&amp;gt; returns {code(success or fail)}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;api/Checkout:&lt;/div&gt;&lt;div&gt;Post: {name, address, cart_id} -&amp;gt; returns {code(success or fail)}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;api/Payment:&amp;nbsp;&lt;/div&gt;&lt;div&gt;Post: {checkout_id, total_amount, card_details} -&amp;gt; returns {code(success or fail)}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;api/Order Status:&lt;/div&gt;&lt;div&gt;Get: {order_id} -&amp;gt; returns {order_id, status, List&amp;lt;product_id, quantity&amp;gt;, delivery_date}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="540" x="3330" y="2710" as="geometry" />
        </mxCell>
